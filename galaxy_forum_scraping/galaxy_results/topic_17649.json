            {
                "id": 41274,
                "name": "Yael",
                "username": "Yael_Gershon",
                "avatar_template": "/user_avatar/help.galaxyproject.org/yael_gershon/{size}/8579_2.png",
                "created_at": "2026-04-11T10:49:17.748Z",
                "cooked": "\u003cp\u003eHi \u003ca class=\"mention\" href=\"/u/jennaj\"\u003e@jennaj\u003c/a\u003e,\u003c/p\u003e\n\u003cp\u003eThank you for the quick response and example history!\u003c/p\u003e\n\u003cp\u003eOne clarification before I test: My library has 12K unique barcodes. I noticed the “Job generated \u0026gt;10000 output datasets” error. Is there a 10K output dataset limit in Barcode Splitter? If so, this exceeds my needs (12K barcodes required).\u003c/p\u003e\n\u003cp\u003eIf limited, are there alternatives for large barcode libraries (\u0026gt;10K) that don’t hit the dataset limit? Local tools or different Galaxy servers with higher quotas?\u003c/p\u003e\n\u003cp\u003eThanks again,\u003cbr\u003e\nYael\u003c/p\u003e",
                "post_number": 3,
                "post_type": 1,
                "posts_count": 5,
                "updated_at": "2026-04-11T10:49:17.748Z",
                "reply_count": 1,
                "reply_to_post_number": null,
                "quote_count": 0,
                "incoming_link_count": 0,
                "reads": 5,
                "readers_count": 4,
                "score": 6.0,
                "yours": false,
